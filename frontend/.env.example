# API base URL (backend)
# Local dev: http://localhost:5000/api
# Netlify production: set in Netlify UI to your Render API, e.g. https://YOUR-SERVICE.onrender.com/api
VITE_API_URL=http://localhost:5000/api
# Vite proxy target (no /api suffix). Default in vite.config is localhost:5000.
# If 5000 is busy, copy this file to .env.local and set the port your backend uses (e.g. 5055).
VITE_API_TARGET=http://localhost:5000

# Site URL for SEO, canonical links (production: https://edulumix.in)
VITE_APP_URL=https://edulumix.in

# Firebase (for Firebase Auth - Google/Email login)
# Get from: Firebase Console > Project Settings > General > Your apps
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=edulumix-9c6d7.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=edulumix-9c6d7
# VITE_FIREBASE_STORAGE_BUCKET=edulumix-9c6d7.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Google AdSense ad unit slot IDs (optional - add when you create ad units in AdSense)
# Get from: AdSense > Ads > By ad unit > [Your ad unit] > Get code > data-ad-slot
# VITE_ADS_SLOT_BANNER=
# VITE_ADS_SLOT_IN_ARTICLE=
# VITE_ADS_SLOT_SIDEBAR=
