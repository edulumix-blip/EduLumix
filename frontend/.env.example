# ---------------------------------------------------------------------------
# Copy to `.env` and `.env.local` for local dev (files are gitignored).
# Netlify: set the same VITE_* keys in Site settings → Environment variables.
# ---------------------------------------------------------------------------

# --- API (required for production build on Netlify) ---
# Public site: your Render backend base URL including /api
VITE_API_URL=https://edulumix.onrender.com/api

# Local dev: browser uses same-origin /api via Vite proxy; this is still set
# for consistency if any code reads it on localhost.
# VITE_API_URL=http://localhost:5000/api

# Vite dev server proxy target (no /api suffix). Must match backend PORT.
VITE_API_TARGET=http://localhost:5000

# --- Site URL (SEO, canonicals) ---
# Production: https://edulumix.in or your Netlify URL until custom domain
VITE_APP_URL=https://edulumix.in

# Local:
# VITE_APP_URL=http://localhost:5173

# --- Google AdSense (optional) ---
# VITE_ADS_SLOT_BANNER=
# VITE_ADS_SLOT_IN_ARTICLE=
# VITE_ADS_SLOT_SIDEBAR=
