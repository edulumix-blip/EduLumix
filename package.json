{
  "name": "edulumix-backend",
  "version": "1.0.0",
  "description": "EduLumix MERN Stack Backend - Career & Education Platform",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "dev:all": "node scripts/dev-all.mjs",
    "start:all": "npm run build:frontend && node backend/server.js",
    "build:frontend": "cd frontend && npm run build",
    "seed": "node backend/utils/seedSuperAdmin.js",
    "test:backend": "npm --prefix backend test",
    "lint:frontend": "npm --prefix frontend run lint",
    "verify": "npm run test:backend && npm run lint:frontend"
  },
  "keywords": [
    "mern",
    "edulumix",
    "jobs",
    "resources",
    "education"
  ],
  "author": "Md Mijanur Molla",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.0",
    "express-validator": "^7.2.0",
    "firebase-admin": "^13.6.0",
    "groq-sdk": "^0.37.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^2.0.0",
    "node-cron": "^4.2.1",
    "rss-parser": "^3.13.0",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
